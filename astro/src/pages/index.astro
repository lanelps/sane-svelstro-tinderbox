---
import Layout from "@layouts/Layout.astro";

import { homePageQuery } from "@/utils/queires";
import { getPageSeo } from "@/utils/helpers";
import { processNestedImages } from "@/utils/image";

import { loadQuery } from "@/utils/load-query";
import type { HomePageData } from "@/types";

const { data: rawPage } = await loadQuery<HomePageData>({
  query: homePageQuery,
});

const page = await processNestedImages(rawPage);

const pageSeo = getPageSeo(page);
---

<Layout seo={pageSeo} grid>
  <h1 class="col-span-full">
    Welcome to Sane Svelstro Tinderbox {page.title} 🔥
  </h1>
</Layout>
