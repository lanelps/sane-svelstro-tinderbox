---
interface LinkMarkDef {
  href: string;
  isExternal: boolean;
}

interface Props {
  node: {
    markDef: LinkMarkDef;
  };
}

const props: LinkMarkDef = (Astro.props as Props).node.markDef;
---

<a
  href={props.href}
  target={props.isExternal ? "_blank" : "_self"}
  rel="noreferrer noopener"
  class="text-b1"><slot /></a
>
