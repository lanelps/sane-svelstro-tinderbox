---
import { getImageProps } from "@utils/image/sanity-image";
import type { SEO, SiteData, Image } from "@/types";

interface Props extends SEO {
  organization?: SiteData["organization"];
}

const { title, description, keywords, image, favicon, createdAt, updatedAt, organization, schema } = Astro.props;

const resizedImage: Image | string | undefined =
  typeof image !== "string" && image?.asset?._ref ? getImageProps({ image, maxWidth: 1920 }) : image as string || undefined;
  
const resizedFavicon = favicon && getImageProps({ image: favicon, maxWidth: 256 });
const orgLogoProps = organization?.logo?.asset?._ref ? getImageProps({ image: organization.logo, maxWidth: 256 }) : undefined;
const authorImageProps = schema?.author?.image?.asset?._ref ? getImageProps({ image: schema.author.image, maxWidth: 256 }) : undefined;

/**
 * @name getImageUrl
 * @function
 * @description Extracts a plain URL string from either a string URL or an Image object, returning undefined if neither yields a URL.
 * @param {Image | string | undefined} image - The image value to resolve.
 * @returns {string | undefined} The image URL string, or undefined.
 */
const getImageUrl = (image: Image | string | undefined) => {
  if (typeof image === "string") {
    return image;
  }
  

  if (image?.src) {
    return image.src;
  }

  return undefined;
};

// Construct JSON-LD data
const orgName = organization?.name ?? title;
const siteOrigin = Astro.url.origin;

const publisher = {
  "@type": "Organization" as const,
  name: orgName,
  url: siteOrigin,
  ...(orgLogoProps?.src && { logo: orgLogoProps.src }),
  ...(organization?.address && {
    address: {
      "@type": "PostalAddress",
      streetAddress: organization.address.street,
      addressLocality: organization.address.city,
      addressRegion: organization.address.state,
      postalCode: organization.address.zipCode,
      addressCountry: organization.address.country,
    },
  }),
};

const author = schema?.author
  ? {
      "@type": "Person" as const,
      name: schema.author.name,
      ...(schema.author.url && { url: schema.author.url }),
      ...(authorImageProps?.src && { image: authorImageProps.src }),
    }
  : undefined;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": schema?.type ?? "WebPage",
  headline: title,
  description: description,
  image: getImageUrl(resizedImage),
  url: Astro.url.href,
  datePublished: createdAt,
  dateCreated: createdAt,
  dateModified: updatedAt,
  ...(author && { author }),
  publisher,
  creator: publisher,
  copyrightYear: new Date().getFullYear(),
  copyrightHolder: { 
    "@type": "Organization",
     name: orgName, 
     url: siteOrigin 
  },
  inLanguage: "en",
  isPartOf: {
    "@type": "WebSite",
    name: orgName,
    url: siteOrigin,
  },
  mainEntity: {
    "@type": "WebPageElement",
    cssSelector: "main",
  },
  breadcrumb: {
    "@type": "BreadcrumbList",
    itemListElement: [
      title
        ? {
            "@type": "ListItem",
            position: 1,
            name: title.split(" - ")[0],
            item: siteOrigin,
          }
        : null,
    ],
  },
  keywords: keywords?.join(", "),
};
---

{import.meta.env.IS_DEV === "true" && (
  <meta name="robots" content="noindex" />
)}

{title && (
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
)}

{description && (
    <meta name="description" content={description} />
    <meta property="og:description" content={description} />
    <meta name="twitter:description" content={description} />
)}

{keywords && <meta name="keywords" content={keywords.join(", ")} />}

{resizedImage && typeof resizedImage !== "string" && (
    <meta property="og:image" content={getImageUrl(resizedImage)} />
    <meta name="twitter:image" content={getImageUrl(resizedImage)} />
)}

{favicon && resizedFavicon?.src && <link rel="icon" type="image/png" href={resizedFavicon.src} />}



<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />